# Copy this file to .env and fill in local values.
BACKEND_URLS=http://0.0.0.0:5038

ConnectionStrings__spApiDb=Server=localhost,1433;Database=sp_backend;User Id=sa;Password=<your-sa-password>;Encrypt=False;TrustServerCertificate=True;
ConnectionStrings__BackupDbContext=Server=localhost,1433;Database=BackupSpApiDB;User Id=sa;Password=<your-sa-password>;Encrypt=False;TrustServerCertificate=True;

Jwt__Key=<at-least-32-byte-secret-key>
Jwt__Issuer=sp_backend
Jwt__Audience=sp_frontend
